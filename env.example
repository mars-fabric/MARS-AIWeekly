# =============================================================================
# AI Weekly Environment Configuration
# =============================================================================

# =============================================================================
# API Keys
# =============================================================================

# OpenAI API Key (required for GPT models)
OPENAI_API_KEY=

# Optional - NewsAPI key for expanded data collection in Stage 1
NEWSAPI_KEY=

# Anthropic API Key (optional, for Claude models)
ANTHROPIC_API_KEY=

# Google Gemini API Key (optional)
GEMINI_API_KEY=

# Perplexity API Key (optional)
PERPLEXITY_API_KEY=

# Azure OpenAI (if using Azure instead of OpenAI directly)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION="

# =============================================================================
# Work Directory Configuration
# =============================================================================

# Root directory for all task outputs, logs, and session data
# Directory structure:
#   {AIWEEKLY_DEFAULT_WORK_DIR}/
#   └── sessions/
#       └── {session_id}/
#           ├── session.log              # Complete audit trail
#           └── tasks/
#               └── {task_id}/
#                   ├── logs/
#                   │   ├── run.log      # Infrastructure events
#                   │   └── console_output.log
#                   ├── cost/            # Cost reports
#                   ├── data/            # Task data
#                   └── ...
AIWEEKLY_DEFAULT_WORK_DIR="~/Desktop/cmbdir/aiweekly"

# Frontend work directory (must have NEXT_PUBLIC_ prefix for Next.js)
# Should match AIWEEKLY_DEFAULT_WORK_DIR to ensure consistency
NEXT_PUBLIC_AIWEEKLY_WORK_DIR="~/Desktop/cmbdir/aiweekly"

# =============================================================================
# Backend Configuration
# =============================================================================

# Backend port
PORT=8000

# Application title
AIWEEKLY_APP_TITLE="AI Weekly"

# Application version
AIWEEKLY_APP_VERSION="1.0.0"

# CORS allowed origins (comma-separated)
AIWEEKLY_CORS_ORIGINS="http://localhost:3000,http://localhost:3001,http://localhost:3002"

# Maximum file upload size (MB)
AIWEEKLY_MAX_FILE_SIZE_MB="10"

# Debug mode (true/false)
AIWEEKLY_DEBUG="false"

# =============================================================================
# Frontend Configuration
# =============================================================================

# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:8000

# WebSocket URL
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# Enable debug mode
NEXT_PUBLIC_DEBUG=false

# =============================================================================
# Logging Configuration
# =============================================================================

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL="INFO"

# Use JSON format for console output (true/false)
LOG_JSON="false"

# Backend system log file location (optional - overrides default)
# Default: {AIWEEKLY_DEFAULT_WORK_DIR}/logs/backend.log
# LOG_FILE="/custom/path/to/backend.log"

# =============================================================================
# Database Configuration
# =============================================================================

# Database URL
DATABASE_URL=postgresql://mars:mars_dev@localhost:5432/mars_aiweekly